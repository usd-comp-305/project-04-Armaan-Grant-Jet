@startuml

interface PredictionStrategy {
    + getProbability(a: Team, b: Team) : double
}

class CSVLoader {
    - filePath : String
    + loadTeams() : List<Team>
}

class Team {
    - ranking : int
    - countryName : String
    - countryCode : String
    - rating : int
    - totalGames : int
    - totalWins : int
    - totalLosses : int
    - goalsScored : int
    - goalsConceded : int
    + getRating() : int
    + getWinRate() : double
    + getGoalDiff() : int
    + getRanking() : int
    + getCountryName() : String
    + getCountryCode() : String
}

class EloStrategy {
    + getProbability(a: Team, b: Team) : double
}

class MatchResult {
    - winner : Team
    - goalsA : int
    - goalsB : int
    - isDraw : boolean
    + getWinner() : Team
    + isDraw() : boolean
    + getGoalsA() : int
    + getGoalsB() : int
}

class Match {
    - teamA : Team
    - teamB : Team
    - strategy : PredictionStrategy
    - isKnockout : boolean
    + play() : MatchResult
    + simulatePenalties() : Team
}

class Standings {
    - team : Team
    - points : int
    - goalDiff : int
    - goalsFor : int
    + addResult(r: MatchResult) : void
    + getPoints() : int
    + getGoalDiff() : int
    + getGoalsFor() : int
    + getTeam() : Team
}

class Group {
    - name : String
    - teams : List<Team>
    - standings : List<Standings>
    + playGroupStage() : void
    + getQualifiers() : List<Team>
    + getStandings() : List<Standings>
    + getName() : String
}

class Bracket {
    - teams : List<Team>
    - round : int
    - strategy : PredictionStrategy
    + playRound() : List<Team>
    + getWinner() : Team
    + getCurrentRound() : int
}

class Tournament {
    - groups : List<Group>
    - bracket : Bracket
    - strategy : PredictionStrategy
    + runGroupStage() : void
    + buildBracket() : void
    + runKnockout() : Team
}

class SimulationResult {
    - winCounts : Map<Team, Integer>
    - totalRuns : int
    + recordWin(t: Team) : void
    + getWinProbability(t: Team) : double
    + getTotalRuns() : int
    + printResults() : void
}

class Simulator {
    - tournament : Tournament
    - result : SimulationResult
    - loader : CSVLoader
    + runSimulations(n: int) : void
}

' Relationships
EloStrategy ..|> PredictionStrategy

CSVLoader ..> Team : creates

Match --> Team
Match --> PredictionStrategy
Match --> MatchResult

Standings --> Team
Standings --> MatchResult

Group *-- Team
Group *-- Standings

Bracket --> PredictionStrategy
Bracket o-- Team

Tournament *-- Group
Tournament *-- Bracket
Tournament --> PredictionStrategy

Simulator *-- Tournament
Simulator *-- SimulationResult
Simulator ..> CSVLoader

@enduml